# Required
DB_PASSWORD=changeme
SECRET_KEY=change-this-to-a-long-random-string
# Set false only for local plain-HTTP development.
COOKIE_SECURE=true

# Optional hosted Stripe Payment Link. Defaults to the Paceline donation page.
DONATE_URL=https://buy.stripe.com/dRm7sFgkK2yb8VwgrZ9AA00

# Strava integration (optional — club feed and member linking)
# Create an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# The Strava club ID (found in your club URL on Strava)
STRAVA_CLUB_ID=
# A refresh token from a club member (admin) used to power the public club feed
# Obtain by running the OAuth flow with scope=read,activity:read
STRAVA_CLUB_REFRESH_TOKEN=
